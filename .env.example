# ============================================================
# PORTAL CURY – VARIÁVEIS DE AMBIENTE
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Porta em que o servidor vai rodar
PORT=3000

# Chave secreta para JWT (OBRIGATÓRIO: troque por uma string aleatória longa)
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=TROQUE_ESTA_CHAVE_POR_UMA_STRING_ALEATORIA_LONGA

# Ambiente
NODE_ENV=production
